{
  "mcpServers": {
    "mcp-1c": {
      "command": "C:\\CursorMCP\\mcp-1c\\mcp-1c.exe",
      "args": [
        "--base",
        "http://localhost/PLACEHOLDER/hs/mcp-1c",
        "--user",
        "%MCP_1C_USER%",
        "--password",
        "%MCP_1C_PASSWORD%"
      ]
    },
    "1c-rest-mcp": {
      "command": "npx",
      "args": ["-y", "@theyahia/1c-rest-mcp"],
      "env": {
        "ONEC_BASE_URL": "http://localhost/PLACEHOLDER",
        "ONEC_LOGIN": "%MCP_1C_USER%",
        "ONEC_PASSWORD": "%MCP_1C_PASSWORD%"
      }
    },
    "litecode": {
      "type": "sse",
      "url": "http://localhost:6004/sse"
    },
    "1c-naparnik": {
      "url": "http://localhost:8007/mcp"
    },
    "1c-syntax-helper": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "http://127.0.0.1:8000/mcp"]
    },
    "v8std": {
      "url": "https://ai.v8std.ru/mcp"
    },
    "code-index": {
      "command": "C:\\CursorMCP\\code-index-mcp\\target\\release\\code-index.exe",
      "args": ["serve", "--path", "REPO=${workspaceFolder}"],
      "env": {
        "CODE_INDEX_HOME": "C:\\CursorMCP\\code-index-mcp\\target\\release"
      }
    },
    "serena": {
      "type": "stdio",
      "command": "C:\\Users\\Admin\\.local\\bin\\uv.exe",
      "args": [
        "run",
        "--directory",
        "C:\\CursorMCP\\serena-main",
        "serena-mcp-server",
        "--context",
        "ide",
        "--project",
        "${workspaceFolder}"
      ],
      "env": {},
      "disabled": false
    }
  }
}
