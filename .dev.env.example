# Параметры проекта — скопируйте в .dev.env и настройте под ПК

PREFIX=ESTI

CONFIG_NAME=ЭСТИ_УправлениеФирмойФранчайзи_УправлениеНебольшойФирмой_CRM
CONFIG_SYNONYM=ЭСТИ: Управление фирмой-франчайзи (2.2.5.90) для 1С:Управление нашей фирмой (3.0.13.342)
CONFIG_VERSION=2.2.5.90
BASE_CONFIG_NAME=УправлениеНебольшойФирмой
BASE_CONFIG_VERSION=3.0.13.342

INFOBASE_PATH=C:\Users\<USER>\Documents\ESTI
WORKSPACE_PATH=C:\Cursor\ESTI
HTTP_PUBLISH_URL=http://localhost/ESTI

COMPANY=Сопровождение
DEVELOPER=<ФИО>

PLATFORM_VERSION=8.5.1.1150
PLATFORM_PATH=C:\Program Files\1cv8\8.5.1.1150\bin

COMMENT_OPEN=// +++ {COMPANY}; {DEVELOPER}; {DATE}; {TASK}
COMMENT_CLOSE=// --- {COMPANY}; {DEVELOPER}; {DATE}; {TASK}

NEW_OBJECTS_IN=extension

INFOBASE_KIND=file
IB_USER=Admin
IB_PASSWORD=<пароль>
EXTENSION_NAME=
EXPORT_PATH=C:\Cursor\ESTI
LOG_PATH=C:\Cursor\ESTI\logs

SUBAGENT_MODEL_CODING=composer-2.5-fast
SUBAGENT_MODEL_LIGHT=composer-2.5-fast
